# Server
PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# Database (use a dedicated app user in production, never root)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=fullstack_db

# Auth
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change-me-in-production
COOKIE_NAME=quicknotes_token
# Set to true only after HTTPS is configured
COOKIE_SECURE=false

# CORS — set to your frontend's origin in production
# Example: http://your-ec2-ip  or  https://yourdomain.com
FRONTEND_ORIGIN=http://localhost:5173
